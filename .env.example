# ===== Voice Microdrama Engine — Environment Variables =====
# Copy this file to `.env` and fill in real values if using real providers.
# Mock mode (default) requires NO keys — the demo runs out of the box.

# ===== LLM Provider =====
# Options: mock | fireworks | amd
# - mock: returns canned narration, no API key needed (default)
# - fireworks: Fireworks AI (AMD-compatible, recommended for hackathon)
# - amd: any OpenAI-compatible endpoint (AMD, OpenAI, etc.)
LLM_PROVIDER=mock

# Fireworks AI (https://fireworks.ai/)
FIREWORKS_API_KEY=
FIREWORKS_MODEL=accounts/fireworks/models/llama-v3-70b-instruct

# AMD-compatible / OpenAI-compatible endpoint
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini

# ===== ASR Provider =====
# Options: mock | browser
# - mock: returns predefined text (default)
# - browser: uses Web Speech API (client-side, no key needed)
ASR_PROVIDER=mock

# ===== TTS Provider =====
# Options: mock | browser
# - mock: text-only mode, no audio (default)
# - browser: uses speechSynthesis API (client-side, no key needed)
TTS_PROVIDER=mock

# ===== Z.ai (optional, for reference) =====
# ZAI_API_KEY=
