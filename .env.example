# ===== Life Blind Box Runtime — Environment Variables =====
# Copy this file to `.env` and fill in real values.
# NEVER commit the filled-in .env file.

# ===== LLM Provider =====
# Options: openai | mock
# - openai: uses OpenAI (required for real gameplay)
# - mock: returns canned narration, no API key needed (development only)
LLM_PROVIDER=openai

# OpenAI API key (required for LLM_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini

# ===== ASR Provider =====
# Options: openai | mock
# - openai: uses OpenAI Whisper (gpt-4o-mini-transcribe)
# - mock: returns predefined text (development only)
ASR_PROVIDER=openai
OPENAI_ASR_MODEL=gpt-4o-mini-transcribe

# ===== TTS Provider =====
# Options: openai | mock
# - openai: uses OpenAI TTS (gpt-4o-mini-tts)
# - mock: text-only mode, no audio (development only)
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=fable
OPENAI_TTS_RESPONSE_FORMAT=wav

# ===== Optional: Founder / tester mode =====
# Enables quota bypass for internal testing
FOUNDER_MODE_ENABLED=false
FOUNDER_DAILY_LIMIT=100
FOUNDER_TOKEN=

# ===== Optional: Quota limits =====
PER_IP_DAILY_LIMIT=5
GLOBAL_DAILY_CAP=200
BETA_DISABLED=false

# ===== Planned (not yet implemented) =====
# Fireworks AI (AMD-compatible, hackathon extension)
# FIREWORKS_API_KEY=
# FIREWORKS_MODEL=accounts/fireworks/models/llama-v3-70b-instruct

